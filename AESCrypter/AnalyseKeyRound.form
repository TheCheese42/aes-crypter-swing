      <component id="6e4ea" class="javax.swing.JTextPane" binding="theNewRoundKeyTextPane" default-binding="true">
        <constraints>
          <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="6" hsize-policy="6" anchor="0" fill="3" indent="0" use-parent-layout="false">
            <preferred-size width="150" height="50"/>
          </grid>
          <gridbag weightx="1.0" weighty="0.0"/>
        </constraints>
        <properties>
          <focusable value="false"/>
          <margin top="5" left="5" bottom="5" right="5"/>
          <text value="The new round key is generated from the previous round key (or cipher key in round 1), column by column.&#10;&#10;For the first column, take the last column of the previous key and rotate it so the first value moves to the end while all other values move one up. Now perform a SubBytes transformation on that column as explained in the encryption rounds. Finally, add that, the first column of the previous key and the given Rcon column together using XOR, value by value.&#10;&#10;The remaining three columns are created as simple as combining the previous column from the new key with the same column from the previous key using XOR, value by value.&#10;&#10;Go to the next round to view the result."/>
        </properties>
      </component>
