                        </constraints>
                        <properties>
                          <margin top="5" left="5" bottom="5" right="5"/>
                          <text value="After regularly multiplying with 2, perform an addition XOR with 0b100011011 but only if the original value was greater than 127.&#10;&#10;To multiply with 3, first multiply with 2 as described above, then perform another XOR with the original value.&#10;&#10;Alternatively, use a lookup table."/>
